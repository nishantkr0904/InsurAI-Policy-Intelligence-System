# InsurAI Backend – Environment Variables
# Copy this file to .env and fill in your values before running.

# Application
APP_NAME="InsurAI Policy Intelligence System"
APP_VERSION="0.1.0"
DEBUG=false

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.1
RERANKER_MODEL=

# MinIO (object storage)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_DOCUMENTS=insurai-documents
MINIO_SECURE=false

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://insurai:insurai@localhost:5433/insurai_db

# Redis (task queue + cache)
REDIS_URL=redis://localhost:6379/0

# Milvus (vector database)
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=insurai_chunks

# Keycloak (authentication – wired in Phase P2)
KEYCLOAK_SERVER_URL=http://localhost:8080
KEYCLOAK_REALM=insurai
KEYCLOAK_CLIENT_ID=insurai-backend
