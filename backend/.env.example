# InsurAI Backend – Environment Variables
# Copy this file to .env and fill in your values before running.

# Application
APP_NAME="InsurAI Policy Intelligence System"
APP_VERSION="0.1.0"
DEBUG=false

# OpenAI
OPENAI_API_KEY=your_openai_api_key
LITELLM_API_KEY=your_litellm_api_key
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.1
RERANKER_MODEL=

# MinIO (object storage)
MINIO_ENDPOINT=minio.example.internal:9000
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key
MINIO_BUCKET_DOCUMENTS=your_documents_bucket
MINIO_SECURE=false

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://db_user:db_password@db_host:5432/db_name

# Redis (task queue + cache)
REDIS_URL=redis://redis_host:6379/0

# Milvus (vector database)
MILVUS_HOST=milvus_host
MILVUS_PORT=19530
MILVUS_COLLECTION=milvus_collection_name

# Keycloak (authentication – wired in Phase P2)
KEYCLOAK_SERVER_URL=https://keycloak.example.internal
KEYCLOAK_REALM=your_keycloak_realm
KEYCLOAK_CLIENT_ID=your_keycloak_client_id
